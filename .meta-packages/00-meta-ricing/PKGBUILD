pkgname=00-meta-ricing
pkgver=1.0
pkgrel=1
pkgdesc="Meta-package for personal Hyprland ricing setup"
arch=('any')

depends=(
    # --- Compositor & Session Management ---
    'hyprland'                       # Dynamic Wayland compositor
    'hyprpolkitagent'                # Polkit authentication agent for Wayland
    'hypridle'                       # Wayland idle management daemon
    'hyprlock'                       # Wayland screen locking utility
    'sddm'                           # Display manager for login

    # --- Desktop Components & Shell ---
    'aylurs-gtk-shell-git'           # Customizable GTK-based shell

    # --- Theming & Appearance ---
    'awww'                           # Animated wallpaper manager
    'matugen'                        # Material Design color theme generator
    'ttf-jetbrains-mono-nerd'        # Monospaced font with developer icons

    # --- Core Applications & System Tools ---
    'ghostty'                        # GPU-accelerated terminal emulator
    'nautilus'                       # Default GNOME file manager
    'micro'                          # Modern and intuitive text editor
    'stow'                           # Symlink farm manager for dotfiles
)

package() {
    # Meta-package: no files to install
    true
}
