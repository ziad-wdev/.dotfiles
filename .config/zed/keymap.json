[
  {
    "bindings": {
      "alt-d": [
        "editor::SelectNext",
        {
          "replace_newest": false,
        },
      ],
    },
    "context": "Editor",
  },
  {
    "bindings": {
      "alt-shift-f": "editor::Format",
    },
    "context": "Editor",
  },
  {
    "bindings": {
      "ctrl-alt-shift-down": null,
    },
    "context": "Editor",
  },
  {
    "bindings": {
      "ctrl-d": "editor::DuplicateLineDown",
    },
    "context": "Editor",
  },
  {
    "bindings": {
      "ctrl-enter": "editor::NewlineBelow",
    },
    "context": "(Editor && mode == full)",
  },
  {
    "bindings": {
      "ctrl-shift-i": null,
    },
    "context": "Editor",
  },
  {
    "bindings": {
      "ctrl-alt-w": "workspace::CloseProject",
    },
  },
]
