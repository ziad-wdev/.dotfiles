{
  "label" : "logout",
  "action" : "hyprctl dispatch exit",
  "text" : "Logout",
  "keybind" : "e"
},
{
  "label" : "lock",
  "action" : "hyprlock",
  "text" : "Lock",
  "keybind" : "l"
},
{
  "label" : "sleep",
  "action" : "hyprlock && systemctl suspend",
  "text" : "Sleep",
  "keybind" : "h"
},
{
  "label" : "reboot",
  "action" : "systemctl reboot",
  "text" : "Reboot",
  "keybind" : "r"
},
{
  "label" : "shutdown",
  "action" : "systemctl poweroff",
  "text" : "Shutdown",
  "keybind" : "s"
}
